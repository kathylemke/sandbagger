{
  "expo": {
    "name": "Sandbagger",
    "slug": "sandbagger",
    "version": "1.0.0",
    "scheme": "sandbagger",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a472a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.katlem5220.sandbagger",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.katlem5220.sandbagger",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a472a"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "output": "single",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "baseUrl": "/sandbagger"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "25ce196e-6604-4137-8c2d-0dfe47b2af52"
      }
    },
    "owner": "katlem5220",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/25ce196e-6604-4137-8c2d-0dfe47b2af52"
    }
  }
}
